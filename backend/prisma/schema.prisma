generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
}

enum FieldType {
  TEXT
  NUMBER
  BOOLEAN
  MEDIA
  RELATION
  RICH_TEXT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contentTypes ContentType[]
}

model ContentType {
  id          String               @id @default(cuid())
  name        String
  apiId       String               @unique
  description String?
  version     Int                  @default(1)
  schema      Json
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)

  schemaFields ContentTypeField[]
  entries      Entry[]

  @@index([apiId])
}

model ContentTypeField {
  id            String   @id @default(cuid())
  contentTypeId String
  name          String
  displayName   String
  type          FieldType
  required      Boolean  @default(false)
  unique        Boolean  @default(false)
  options       Json?
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@index([contentTypeId])
  @@unique([contentTypeId, name])
}

model Entry {
  id            String   @id @default(cuid())
  contentTypeId String
  data          Json
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@index([contentTypeId])
}

model MediaFile {
  id           String   @id @default(cuid())
  originalName String
  filename     String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
}
